{
  "schema": "AgriServiceResource",
  "version": "2.1.0",
  "card_template": "{{descriptor.name}} | {{serviceCategory}} | {{serviceAreaHierarchy.county}}, {{serviceAreaHierarchy.country}}",
  "detail_template": "{{descriptor.name}}\nService: {{serviceCategory}}\nProvider: {{providerType}}\nLivestock: {{#each livestockTypes}}{{this}} {{/each}}\nArea: {{serviceAreaHierarchy.village}}, {{serviceAreaHierarchy.ward}}, {{serviceAreaHierarchy.county}}\nCoverage: {{serviceAreaHierarchy.coverageRadiusKm}}km",
  "html": "<div class=\"agri-service-resource-card\" data-resource-id=\"{{beckn:id}}\"><span class=\"category\">{{beckn:resourceAttributes.serviceCategory}}</span><h3>{{beckn:descriptor.schema:name}}</h3><span class=\"provider\">{{beckn:resourceAttributes.providerType}}</span><span class=\"location\">{{beckn:resourceAttributes.serviceAreaHierarchy.county}}, {{beckn:resourceAttributes.serviceAreaHierarchy.country}}</span></div>",
  "html_detail": "<div class=\"agri-service-resource-detail\" data-resource-id=\"{{beckn:id}}\"><h2>{{beckn:descriptor.schema:name}}</h2><dl><dt>Service Category</dt><dd>{{beckn:resourceAttributes.serviceCategory}}</dd><dt>Provider Type</dt><dd>{{beckn:resourceAttributes.providerType}}</dd><dt>Livestock Types</dt><dd>{{#each beckn:resourceAttributes.livestockTypes}}<span class=\"badge\">{{this}}</span> {{/each}}</dd><dt>Service Area</dt><dd>{{beckn:resourceAttributes.serviceAreaHierarchy.village}}, {{beckn:resourceAttributes.serviceAreaHierarchy.ward}}<br/>{{beckn:resourceAttributes.serviceAreaHierarchy.county}}, {{beckn:resourceAttributes.serviceAreaHierarchy.country}}</dd><dt>Coverage Radius</dt><dd>{{beckn:resourceAttributes.serviceAreaHierarchy.coverageRadiusKm}} km</dd><dt>Service Unit</dt><dd>{{beckn:resourceAttributes.serviceUnit}}</dd><dt>Capacity/Day</dt><dd>{{beckn:resourceAttributes.capacityPerDay}}</dd></dl></div>"
}
